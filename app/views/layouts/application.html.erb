<!DOCTYPE html>
<html>
<head>
  <title>Game Rental</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>

<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
  <div class="container">
    <%= link_to "Game Rental", games_path, class: "navbar-brand", data: { turbo_frame: "games" } %>

    <ul class="navbar-nav">
      <li class="nav-item">
        <%= link_to "Gry", games_path, class: "nav-link", data: { turbo_frame: "games" } %>
      </li>
      <li class="nav-item">
        <%= link_to "Wypożyczenia", rentals_path, class: "nav-link", data: { turbo_frame: "rentals" } %>
      </li>
      <li class="nav-item">
        <%= link_to "Recenzje", reviews_path, class: "nav-link", data: { turbo_frame: "reviews" } %>
      </li>
    </ul>
  </div>
</nav>

<div class="container">
  <%= turbo_frame_tag "games"%>
  <%= turbo_frame_tag "rentals" %>
  <%= turbo_frame_tag "reviews" %>



</div>
</body>
</html>
